<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="
            http://www.liquibase.org/xml/ns/dbchangelog
            http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.23.xsd">

    <changeSet id="create schema ural_auth" author="kerzhakov">
        <sql>
            CREATE SCHEMA IF NOT EXISTS ural_auth
        </sql>
    </changeSet>

    <changeSet id="create table users" author="kerzhakov">
        <createTable tableName="users">
            <column name="uuid" type="UUID">
                <constraints primaryKey="true"/>
            </column>
            <column name="login" type="VARCHAR(255)">
                <constraints nullable="false" unique="true"/>
            </column>
         </createTable>
    </changeSet>

    <changeSet id="create-table-role" author="">
        <createTable tableName="roles">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true"/>
            </column>
            <column name="name" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="code" type="VARCHAR(255)">
                <constraints nullable="false" unique="true"/>
            </column>
        </createTable>
    </changeSet>

    <changeSet id="create-table-users_roles" author="kerzhakov">
        <createTable tableName="users_roles">
            <column name="user_uuid" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="role_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addForeignKeyConstraint baseTableName="users_roles"
                                 baseColumnNames="user_uuid"
                                 constraintName="users_roles_user_uuid_fk"
                                 referencedTableName="users"
                                 referencedColumnNames="uuid"
                                 deleteCascade="true"/>
        <addForeignKeyConstraint baseTableName="users_roles"
                                 baseColumnNames="role_id"
                                 constraintName="users_roles_role_id_fk"
                                 referencedTableName="roles"
                                 referencedColumnNames="id"
                                 deleteCascade="true"/>
        <addPrimaryKey tableName="users_roles"
                       columnNames="user_uuid, role_id"
                       constraintName="stop_factors_stop_factor_groups_pk"/>
    </changeSet>

    <changeSet id="create-table-cridentials" author="kerzhakov">
        <createTable tableName="credentials">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true"/>
            </column>
            <column name="hash" type="TEXT">
                <constraints nullable="false"/>
            </column>
            <column name="salt" type="TEXT">
                <constraints nullable="false"/>
            </column>
            <column name="user_uuid" type="UUID">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addForeignKeyConstraint baseTableName="credentials"
                                 baseColumnNames="user_uuid"
                                 constraintName="credentials_user_uuid_fk"
                                 referencedTableName="users"
                                 referencedColumnNames="uuid"/>
    </changeSet>

    <changeSet id="create-table-refresh-tokens" author="kerzhakov">
        <createTable tableName="refresh_tokens">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints nullable="false"/>
            </column>
            <column name="access_jti" type="TEXT">
                <constraints nullable="false"/>
            </column>
            <column name="refresh_jti" type="TEXT">
                <constraints nullable="false"/>
            </column>
            <column name="token" type="TEXT">
                <constraints nullable="false"/>
            </column>
            <column name="issued_at" type="TIMESTAMPTZ">
                <constraints nullable="false"/>
            </column>
            <column name="expired_at" type="TIMESTAMPTZ">
                <constraints nullable="false"/>
            </column>
            <column name="user_uuid" type="UUID">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addForeignKeyConstraint baseTableName="refresh_tokens" baseColumnNames="user_uuid"
                                 constraintName="refresh_tokens_user_uuid_fk"
                                 referencedTableName="users"
                                 referencedColumnNames="uuid"/>
    </changeSet>

    <changeSet id="add-column-for-users" author="kerzhakov">
        <addColumn tableName="users">
            <column name="email" type="TEXT">
                <constraints nullable="false" unique="true"/>
            </column>
        </addColumn>
    </changeSet>

    <changeSet id="drop-email-from-users" author="codex">
        <preConditions onFail="MARK_RAN">
            <columnExists tableName="users" columnName="email"/>
        </preConditions>
        <dropColumn tableName="users" columnName="email"/>
    </changeSet>

    <changeSet id="insert roles" author="kerzhakov">
        <sql>
            INSERT INTO roles (code, name) VALUES
            ('USER', 'Пользователь'),
            ('ADMIN', 'Администратор'),
            ('UNDERWRITER', 'Редактор')
        </sql>
    </changeSet>

</databaseChangeLog>
